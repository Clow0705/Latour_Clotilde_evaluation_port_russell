<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Détail Catway</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <a href="/dashboard">🏠 Tableau de bord</a>
    <a href="/page-catways">⚓ Catways</a>
    <a href="/page-reservations">📅 Réservations</a>
    <a href="/page-users">👥 Utilisateurs</a>
    <a href="/logout">🚪 Déconnexion</a>
  </nav>
  <div class="container">
    <h1>⚓ Détail du Catway N°<%= catway.catwayNumber %></h1>

    <p><strong>Numéro :</strong> <%= catway.catwayNumber %></p>
    <p><strong>Type :</strong> <%= catway.catwayType %></p>
    <p><strong>État :</strong> <%= catway.catwayState %></p>

    <h2>Modifier l'état</h2>
    <form action="/catways/<%= catway.catwayNumber %>?_method=PUT" method="POST">
      <input type="text" name="catwayState" value="<%= catway.catwayState %>" required />
      <button type="submit">Enregistrer</button>
    </form>

    <a href="/page-catways">← Retour à la liste</a>
  </div>
</body>
</html>